	$hc_current_custom_language_label = 'FR';
} elseif ( $hc_current_language === 'es' ) {
	$hc_current_custom_language_label = 'ES';
} elseif ( $hc_current_language === 'pt' || $hc_current_language === 'pt-pt' ) {
	$hc_current_custom_language_label = 'PT';
