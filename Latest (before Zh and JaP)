$hc_wpml_current_page_languages = array();

if ( function_exists( 'icl_get_languages' ) ) {
	$hc_wpml_current_page_languages = icl_get_languages( 'skip_missing=0&orderby=code' );
}

$hc_get_wpml_language_url = function( $target_language_code ) use ( $hc_wpml_current_page_languages ) {
	if ( isset( $hc_wpml_current_page_languages[ $target_language_code ]['url'] ) && ! empty( $hc_wpml_current_page_languages[ $target_language_code ]['url'] ) ) {
		return $hc_wpml_current_page_languages[ $target_language_code ]['url'];
	}

	return apply_filters( 'wpml_permalink', home_url( '/' ), $target_language_code );
};

