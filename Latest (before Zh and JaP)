	$hc_current_page_slug === 'veterinary-imaging-solutions-home' ||
	$hc_current_page_title === 'Veterinary Imaging Solutions - Home'
);

/**
 * Translation preview handling.
 * Home ES draft keeps the home header only on page ID 4740.
 * Home PT draft keeps the home header only on page ID 6101.
 * Other ES/PT preview pages keep the custom language dropdown but use the normal white header.
 * EN and FR live pages are not affected.
 */
$hc_request_uri = isset( $_SERVER['REQUEST_URI'] ) ? $_SERVER['REQUEST_URI'] : '';

$hc_is_spanish_preview_page = (
	$hc_current_language === 'es'
	&& isset( $_GET['preview'] )
	&& $_GET['preview'] === 'true'
	&& strpos( $hc_request_uri, '/es/' ) !== false
);

$hc_is_spanish_home_draft_preview = (
	$hc_current_language === 'es'
	&& (int) $hc_current_page_id === 4740
);

$hc_is_portuguese_preview_page = (
	( $hc_current_language === 'pt' || $hc_current_language === 'pt-pt' )
	&& isset( $_GET['preview'] )
	&& $_GET['preview'] === 'true'
	&& ( strpos( $hc_request_uri, '/pt/' ) !== false || strpos( $hc_request_uri, '/pt-pt/' ) !== false )
);

$hc_is_portuguese_home_draft_preview = (
	( $hc_current_language === 'pt' || $hc_current_language === 'pt-pt' )
	&& (int) $hc_current_page_id === 6101
);

